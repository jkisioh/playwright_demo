# TDT Playwright Test Configuration
# Copy this file to .env and update the values for your environment

# Frontend URL to test
# Local: http://localhost:3000
# Staging (default): https://tdt.akvotest.org
BASE_URL=https://tdt.akvotest.org
USERNAME=test@test.org
PASSWORD=123

# Strapi CMS URL
# Local: http://localhost:1337
# Staging (default): https://tdt.akvotest.org/cms
STRAPI_URL=https://tdt.akvotest.org/cms

# Strapi admin credentials (required for Strapi tests)
STRAPI_EMAIL=test@test.org
STRAPI_PASSWORD=123
RUN_STRAPI_TESTS=false